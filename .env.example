# Copy to .env and fill in from the Supabase dashboard (Project Settings → API).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push VAPID public key (the private key lives ONLY in the Supabase edge
# function secrets: VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY / VAPID_SUBJECT).
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
